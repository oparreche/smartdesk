// 7. Integrações HTTP
// =========================

model ApiIntegration {
  id              String         @id @default(uuid()) @db.Char(36)
  organizationId  String                                       @map("organization_id") @db.Char(36)
  name            String
  description     String?        @db.Text
  enabled         Boolean        @default(true)

  triggerEvents   Json                                         @map("trigger_events")
  conditions      Json?
  runOrder        Int            @default(0)                   @map("run_order")

  method          HttpMethod
  url             String         @db.Text
  headers         Json?
  queryParams     Json?                                        @map("query_params")
  bodyTemplate    Json?                                        @map("body_template")

  authType        AuthType                                     @map("auth_type")
  authConfigEnc   String?        @db.Text                      @map("auth_config_enc")
  authConfigNonce String?                                      @map("auth_config_nonce")

  timeoutMs       Int            @default(10000)               @map("timeout_ms")
  maxRetries      Int            @default(2)                   @map("max_retries")
  cacheTtlSeconds Int            @default(0)                   @map("cache_ttl_seconds")

  responseMapping    Json                                      @map("response_mapping")
  /**
   * Caminho (alias do responseMapping) que **precisa** vir preenchido para
   * considerar match real. Se vazio depois do mapping, run vira `skipped`
   * (não salva enrichment, não dispara `ticket_enriched`).
   * Ex.: "partner.id" — protege contra APIs que devolvem 200+stub genérico.
   */
  requiredMatchField String?       @db.VarChar(200)              @map("required_match_field")
  failurePolicy      FailurePolicy @default(skip)                @map("failure_policy")

  createdAt       DateTime       @default(now())               @map("created_at")
  updatedAt       DateTime       @updatedAt                    @map("updated_at")
  deletedAt       DateTime?                                    @map("deleted_at")

  organization    Organization        @relation(fields: [organizationId], references: [id])
  runs            ApiIntegrationRun[]
  enrichments     TicketEnrichment[]

  @@index([organizationId, enabled])
  @@map("api_integrations")
}

enum HttpMethod {
  GET
  POST
  PUT
  PATCH
}

enum AuthType {
  none
  api_key_header
  api_key_query
  bearer
  basic
  custom_headers
}

enum FailurePolicy {
  skip
  retry_later
  flag_ticket
}

model ApiIntegrationRun {
  id              String         @id @default(uuid()) @db.Char(36)
  organizationId  String                                       @map("organization_id") @db.Char(36)
  integrationId   String                                       @map("integration_id") @db.Char(36)
  ticketId        String?                                      @map("ticket_id") @db.Char(36)
  triggeredBy     String                                       @map("triggered_by")
