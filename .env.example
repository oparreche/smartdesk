# ─────────────────────────────────────────────────────────────
# SmartDesk — .env.example
# Copie para .env.local e preencha os valores. Não commitar .env.local.
# ─────────────────────────────────────────────────────────────

# App
NODE_ENV=development
APP_URL=http://localhost:3000

# Database (Docker compose)
DATABASE_URL="mysql://smartdesk:smartdesk@localhost:3306/smartdesk"

# Auth.js (NextAuth v5)
# Gerar com: openssl rand -base64 32
AUTH_SECRET=
AUTH_TRUST_HOST=true

# Google OAuth (login + Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Criptografia de secrets (32 bytes em base64)
# Gerar com: pnpm gen-key
ENCRYPTION_KEY_BASE64=

# Cron — bearer dos endpoints /api/cron/*
CRON_SECRET=

# Storage (MinIO em dev)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=smartdesk-attachments
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# Gmail OAuth redirect (usa o mesmo client do GOOGLE_*)
GMAIL_REDIRECT_URI=http://localhost:3000/api/integrations/gmail/connect/callback

# Logs
LOG_LEVEL=info

# Email transacional
# Dev: MailHog em smtp://localhost:1025 (UI em http://localhost:8025) — sem auth
# Prod: SMTP do seu provider (Resend / SES / Mailgun)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false
EMAIL_FROM="SmartDesk <noreply@smartdesk.local>"

# IA — Gemini (Google AI Studio). Opcional. Sem isso o painel "Assistente IA" fica desativado.
# Gere chave em https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
